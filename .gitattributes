# Normalize all text files to LF on commit
* text=auto eol=lf

*.kt        text eol=lf
*.kts       text eol=lf
*.java      text eol=lf
*.xml       text eol=lf
*.json      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.md        text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.sh        text eol=lf
*.properties text eol=lf

# Binary files — never diff or convert
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       binary
*.pdf       binary
*.apk       binary
*.jar       binary
*.keystore  binary
*.jks       binary
*.zip       binary
*.tar.gz    binary
